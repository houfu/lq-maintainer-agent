{
  "permissions": {
    "deny": [
      "Bash(gh pr merge)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr review)",
      "Bash(gh pr review:*)",
      "Bash(gh pr close)",
      "Bash(gh pr close:*)",
      "Bash(gh pr checkout)",
      "Bash(gh pr checkout:*)",
      "Bash(gh issue close)",
      "Bash(gh issue close:*)",
      "Bash(gh repo delete)",
      "Bash(gh repo delete:*)",
      "Bash(gh alias set:*)",
      "Bash(gh alias import:*)",
      "Bash(gh api graphql)",
      "Bash(gh api graphql:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git send-pack)",
      "Bash(git send-pack:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh \"${CLAUDE_PLUGIN_ROOT}/settings/hooks/block-writes.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
